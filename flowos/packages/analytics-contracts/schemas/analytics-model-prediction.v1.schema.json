{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://flowos.dev/contracts/analytics-model-prediction.v1.schema.json",
  "title": "Analytics model and prediction contracts v1",
  "$defs": {
    "modelFamily": { "enum": ["ridge_linear", "poisson_glm", "histogram_gradient_boosting"] },
    "metrics": {
      "type": "object",
      "required": ["wape", "mae", "rmse", "r2", "bias"],
      "properties": { "wape": { "type": "number" }, "mae": { "type": "number" }, "rmse": { "type": "number" }, "r2": { "type": "number" }, "bias": { "type": "number" } }
    },
    "trainingRequest": {
      "type": "object",
      "required": ["contractVersion", "trainingDatasetVersionId", "target", "candidateAlgorithms"],
      "properties": {
        "contractVersion": { "const": "analytics.v1" }, "trainingDatasetVersionId": { "type": "string", "minLength": 1 }, "target": { "const": "sales_units" },
        "candidateAlgorithms": { "type": "array", "minItems": 1, "items": { "$ref": "#/$defs/modelFamily" } }, "includeBaselineUnits": { "type": "boolean" }, "validationWeeks": { "type": "integer", "minimum": 1, "maximum": 52 },
        "thresholds": { "type": "object", "properties": { "maxWape": { "type": "number", "minimum": 0 } } }
      }
    },
    "futureForecast": {
      "type": "object",
      "required": ["mode", "rows"],
      "properties": {
        "mode": { "const": "future_forecast" },
        "rows": { "type": "array", "minItems": 4, "maxItems": 4, "items": { "type": "object", "required": ["productId", "customerId", "weekNum", "consumerPrice", "numStores", "promotionIntensity"], "properties": { "productId": { "type": "string", "minLength": 1 }, "customerId": { "type": "string", "minLength": 1 }, "weekNum": { "type": "string", "pattern": "^\\d{4}-(?:W)?\\d{1,2}$" }, "consumerPrice": { "type": "number" }, "numStores": { "type": "number" }, "promotionIntensity": { "type": "number", "minimum": 0, "maximum": 1 } } } }
      }
    },
    "predictionOutputSummary": {
      "type": "object",
      "required": ["rowCount", "totalBaselineUnits", "totalPromotedUnits", "totalIncrementalUnits", "weightedPercentIncrement", "qualityFlags"],
      "properties": { "rowCount": { "type": "integer", "minimum": 0 }, "totalBaselineUnits": { "type": "number" }, "totalPromotedUnits": { "type": "number" }, "totalIncrementalUnits": { "type": "number" }, "weightedPercentIncrement": { "type": "number" }, "qualityFlags": { "type": "array", "items": { "type": "string" } } }
    }
  }
}
