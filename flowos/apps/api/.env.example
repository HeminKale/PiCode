# Copy this file to .env and fill in real values.
# .env is gitignored — never commit real secrets.

# Supabase — pooled connection (port 6543), used at runtime. Append ?pgbouncer=true
DATABASE_URL="postgresql://postgres:[YOUR-PASSWORD]@db.[project-ref].supabase.co:6543/postgres?pgbouncer=true"

# Supabase — direct connection (port 5432), used only for Prisma migrations
DIRECT_URL="postgresql://postgres:[YOUR-PASSWORD]@db.[project-ref].supabase.co:5432/postgres"

# Primary provider — OpenAI
OPENAI_API_KEY="sk-..."
OPENAI_MODEL="gpt-4o"
LLM_PROVIDER="openai"

# Google Gemini â€” optional provider. Set LLM_PROVIDER="gemini" to activate.
# The free tier is rate-limited; review Google's current data-use and quota terms before production use.
GEMINI_API_KEY="..."
GEMINI_MODEL="gemini-2.5-flash"
# Temporary diagnosis only. Logs at most the first 2,000 characters of a rejected LLM response.
# Never enable this for sensitive production data.
LLM_DEBUG_RESPONSES="false"

# Anthropic — registered as a provider in LLMFactory but not the active default
ANTHROPIC_API_KEY="sk-ant-..."
CLAUDE_MODEL="claude-sonnet-4-6"

# Server
PORT=3001

# AES-256-GCM key for encrypting stored connector credentials — base64, must decode to exactly 32 bytes
# Generate with: node -e "console.log(require('crypto').randomBytes(32).toString('base64'))"
CONNECTOR_ENCRYPTION_KEY="..."

# apps/java-runtime base URL (see application.properties there for the port)
JAVA_RUNTIME_URL="http://localhost:8081"
