# Copy this file to .env and fill in real values.
# .env is gitignored — never commit real secrets.

# Supabase — pooled connection (port 6543), used at runtime. Append ?pgbouncer=true
DATABASE_URL="postgresql://postgres:[YOUR-PASSWORD]@db.[project-ref].supabase.co:6543/postgres?pgbouncer=true"

# Supabase — direct connection (port 5432), used only for Prisma migrations
DIRECT_URL="postgresql://postgres:[YOUR-PASSWORD]@db.[project-ref].supabase.co:5432/postgres"

# Anthropic
ANTHROPIC_API_KEY="sk-ant-..."
LLM_PROVIDER="claude"
CLAUDE_MODEL="claude-sonnet-4-6"

# Server
PORT=3001
